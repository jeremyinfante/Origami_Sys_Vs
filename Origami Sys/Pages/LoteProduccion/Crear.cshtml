@page
@model Origami_Sys.Pages.LoteProduccion.CrearModel
@{
    ViewData["Title"] = "Registrar Lote de Producción";
    ViewData["Modulo"] = "Inventario";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0">Registrar Lote — <span class="text-muted small">@Model.NumeroLote</span></h5>
    <a asp-page="Index" class="btn btn-sm btn-outline-secondary">← Volver</a>
</div>

<form method="post">
    <input type="hidden" name="NumeroLote" value="@Model.NumeroLote" />

    <div class="row mb-3">
        <div class="col-md-4">
            <label class="form-label">Fecha</label>
            <input type="date" name="Fecha" class="form-control"
                   value="@DateTime.Today.ToString("yyyy-MM-dd")" />
        </div>
        <div class="col-md-8">
            <label class="form-label">Observaciones</label>
            <input type="text" name="Observaciones" class="form-control" placeholder="Opcional" />
        </div>
    </div>

    <div class="row g-3">
        <!-- Materias primas consumidas -->
        <div class="col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white">
                    <strong class="small">Materias Primas Consumidas</strong>
                </div>
                <div class="card-body">
                    <div class="d-flex gap-2 mb-2">
                        <select id="mpSelect" class="form-select form-select-sm">
                            <option value="">-- Materia Prima --</option>
                            @foreach (var m in Model.MateriasPrimas)
                            {
                                <option value="@m.Id" data-nombre="@m.Nombre"
                                        data-unidad="@m.UnidadMedida"
                                        data-stock="@m.StockActual">
                                    @m.Nombre (Stock: @m.StockActual @m.UnidadMedida)
                                </option>
                            }
                        </select>
                        <input type="number" id="mpCantidad" class="form-control form-control-sm"
                               placeholder="Cantidad" min="0.01" step="0.01" style="width:110px" />
                        <button type="button" class="btn btn-success btn-sm" onclick="agregarMP()">+</button>
                    </div>
                    <table class="table table-sm mb-0">
                        <thead class="table-light">
                            <tr><th>Materia Prima</th><th>Cantidad</th><th></th></tr>
                        </thead>
                        <tbody id="mpBody"></tbody>
                    </table>
                    <div id="mpHiddens"></div>
                </div>
            </div>
        </div>

        <!-- Productos generados -->
        <div class="col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white">
                    <strong class="small">Productos Generados</strong>
                </div>
                <div class="card-body">
                    <div class="d-flex gap-2 mb-2">
                        <select id="prodSelect" class="form-select form-select-sm">
                            <option value="">-- Producto --</option>
                            @foreach (var p in Model.Productos)
                            {
                                <option value="@p.Id" data-nombre="@p.Nombre">
                                    @p.Nombre
                                </option>
                            }
                        </select>
                        <input type="number" id="prodCantidad" class="form-control form-control-sm"
                               placeholder="Cantidad" min="1" style="width:110px" />
                        <button type="button" class="btn btn-success btn-sm" onclick="agregarProd()">+</button>
                    </div>
                    <table class="table table-sm mb-0">
                        <thead class="table-light">
                            <tr><th>Producto</th><th>Cantidad</th><th></th></tr>
                        </thead>
                        <tbody id="prodBody"></tbody>
                    </table>
                    <div id="prodHiddens"></div>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-success" id="btnGuardar" disabled>
            Registrar Lote
        </button>
        <a asp-page="Index" class="btn btn-secondary">Cancelar</a>
    </div>
</form>

@section Scripts {
<script>
    let mps = [], prods = [];

    function agregarMP() {
        const sel = document.getElementById('mpSelect');
        const opt = sel.options[sel.selectedIndex];
        if (!opt.value) { alert('Seleccione una materia prima'); return; }

        const cantidad = parseFloat(document.getElementById('mpCantidad').value);
        const stock = parseFloat(opt.dataset.stock);
        if (!cantidad || cantidad <= 0) { alert('Ingrese una cantidad válida'); return; }
        if (cantidad > stock) { alert(`Stock insuficiente. Disponible: ${stock} ${opt.dataset.unidad}`); return; }
        if (mps.find(m => m.id == opt.value)) { alert('Ya está en la lista'); return; }

        mps.push({ id: opt.value, nombre: opt.dataset.nombre, unidad: opt.dataset.unidad, cantidad });
        renderMP();
        sel.value = '';
        document.getElementById('mpCantidad').value = '';
    }

    function eliminarMP(i) { mps.splice(i, 1); renderMP(); }

    function renderMP() {
        const tbody = document.getElementById('mpBody');
        tbody.innerHTML = '';
        mps.forEach((m, i) => {
            tbody.innerHTML += `<tr>
                <td>${m.nombre}</td>
                <td>${m.cantidad} ${m.unidad}</td>
                <td><button type="button" class="btn btn-danger btn-sm" onclick="eliminarMP(${i})">✕</button></td>
            </tr>`;
        });
        const h = document.getElementById('mpHiddens');
        h.innerHTML = '';
        mps.forEach((m, i) => {
            h.innerHTML += `
                <input type="hidden" name="MateriasUsadas[${i}].MateriaPrimaId" value="${m.id}" />
                <input type="hidden" name="MateriasUsadas[${i}].CantidadUsada" value="${m.cantidad}" />`;
        });
        validarBoton();
    }

    function agregarProd() {
        const sel = document.getElementById('prodSelect');
        const opt = sel.options[sel.selectedIndex];
        if (!opt.value) { alert('Seleccione un producto'); return; }

        const cantidad = parseInt(document.getElementById('prodCantidad').value);
        if (!cantidad || cantidad < 1) { alert('Ingrese una cantidad válida'); return; }
        if (prods.find(p => p.id == opt.value)) { alert('Ya está en la lista'); return; }

        prods.push({ id: opt.value, nombre: opt.dataset.nombre, cantidad });
        renderProd();
        sel.value = '';
        document.getElementById('prodCantidad').value = '';
    }

    function eliminarProd(i) { prods.splice(i, 1); renderProd(); }

    function renderProd() {
        const tbody = document.getElementById('prodBody');
        tbody.innerHTML = '';
        prods.forEach((p, i) => {
            tbody.innerHTML += `<tr>
                <td>${p.nombre}</td>
                <td>${p.cantidad}</td>
                <td><button type="button" class="btn btn-danger btn-sm" onclick="eliminarProd(${i})">✕</button></td>
            </tr>`;
        });
        const h = document.getElementById('prodHiddens');
        h.innerHTML = '';
        prods.forEach((p, i) => {
            h.innerHTML += `
                <input type="hidden" name="ProductosGenerados[${i}].ProductoId" value="${p.id}" />
                <input type="hidden" name="ProductosGenerados[${i}].CantidadProducida" value="${p.cantidad}" />`;
        });
        validarBoton();
    }

    function validarBoton() {
        document.getElementById('btnGuardar').disabled = mps.length === 0 || prods.length === 0;
    }
</script>
}