@page
@model Origami_Sys.Pages.LoteProduccion.CrearModel
@{
    ViewData["Title"] = "Registrar Lote de Producción";
    ViewData["Modulo"] = "Inventario";
}

<style>
    :root{--g-dark:#1a4332;--g-bright:#10b981;--border:#e5e7eb;--text:#1f2937;--muted:#6b7280;}
    .page-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;padding-bottom:16px;border-bottom:1px solid var(--border);}
    .page-header h1{font-size:20px;font-weight:700;color:var(--g-dark);margin:0;}
    .breadcrumb-txt{font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.8px;margin-bottom:3px;}
    .lote-num{font-family:monospace;color:var(--g-bright);font-size:13px;font-weight:600;}
    .card-clean{background:white;border:1px solid var(--border);border-radius:12px;box-shadow:0 1px 4px rgba(0,0,0,.05);margin-bottom:16px;}
    .card-header-custom{padding:12px 18px;background:#fafafa;border-bottom:1px solid var(--border);font-size:11px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;display:flex;align-items:center;gap:8px;}
    .form-label{font-size:12px;font-weight:600;color:#374151;margin-bottom:5px;}
    .form-control,.form-select{font-size:13px;border-color:var(--border);border-radius:7px;padding:7px 11px;transition:border-color .15s,box-shadow .15s;}
    .form-control:focus,.form-select:focus{border-color:var(--g-bright);box-shadow:0 0 0 3px rgba(16,185,129,.1);outline:none;}
    .agregar-row{display:flex;gap:8px;align-items:flex-end;margin-bottom:12px;}
    .agregar-row .form-select,.agregar-row .form-control{font-size:13px;}
    .btn-agregar{display:inline-flex;align-items:center;justify-content:center;gap:5px;background:var(--g-dark);color:white;border:none;padding:7px 14px;border-radius:7px;font-size:13px;font-weight:600;cursor:pointer;white-space:nowrap;transition:background .15s;}
    .btn-agregar:hover{background:#2d5a3d;}
    .chips-table{width:100%;border-collapse:collapse;font-size:13px;}
    .chips-table th{font-size:10.5px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.4px;padding:6px 10px;border-bottom:1px solid var(--border);}
    .chips-table td{padding:8px 10px;border-bottom:1px solid #f3f4f6;vertical-align:middle;}
    .chips-table tr:last-child td{border-bottom:none;}
    .chip-mp{display:inline-flex;align-items:center;gap:4px;background:#fff7ed;color:#b45309;font-size:11px;font-weight:600;padding:3px 8px;border-radius:20px;}
    .chip-prod{display:inline-flex;align-items:center;gap:4px;background:#ecfdf5;color:#166534;font-size:11px;font-weight:600;padding:3px 8px;border-radius:20px;}
    .btn-remove{background:none;border:none;color:#9ca3af;cursor:pointer;font-size:14px;padding:2px 5px;border-radius:4px;transition:color .15s,background .15s;}
    .btn-remove:hover{color:#ef4444;background:#fef2f2;}
    .empty-chips{text-align:center;padding:20px;color:var(--muted);font-size:12px;}
    .btn-save{display:inline-flex;align-items:center;gap:7px;background:var(--g-dark);color:white;border:none;padding:8px 22px;border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;transition:background .15s,transform .1s;}
    .btn-save:hover{background:#2d5a3d;transform:translateY(-1px);}
    .btn-save:disabled{background:#9ca3af;cursor:not-allowed;transform:none;}
    .btn-back{display:inline-flex;align-items:center;gap:6px;background:white;color:var(--muted);border:1px solid var(--border);padding:8px 16px;border-radius:8px;font-size:13px;text-decoration:none;transition:background .15s;}
    .btn-back:hover{background:#f9fafb;color:var(--text);}
    .stock-badge{font-size:11px;color:var(--muted);margin-left:4px;}
</style>

<div class="page-header">
    <div>
        <div class="breadcrumb-txt">@ViewData["Modulo"] / Lotes / Nuevo</div>
        <div class="d-flex align-items-center gap-2">
            <h1>Registrar Lote</h1>
            <span class="lote-num">@Model.NumeroLote</span>
        </div>
    </div>
    <a asp-page="Index" class="btn-back">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m15 18-6-6 6-6"/></svg>
        Volver
    </a>
</div>

<form method="post" id="formLote">
    <input type="hidden" name="NumeroLote" value="@Model.NumeroLote" />

    <!-- Datos generales -->
    <div class="card-clean">
        <div class="card-header-custom">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            Datos del Lote
        </div>
        <div class="card-body p-3">
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">Fecha <span class="text-danger">*</span></label>
                    <input type="date" name="Fecha" class="form-control" value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-9">
                    <label class="form-label">Observaciones</label>
                    <input type="text" name="Observaciones" class="form-control" placeholder="Notas del lote, condiciones de producción, etc." />
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <!-- Materias primas -->
        <div class="col-md-6">
            <div class="card-clean">
                <div class="card-header-custom" style="color:#b45309;">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
                    Materias Primas Consumidas
                </div>
                <div class="card-body p-3">
                    <div class="agregar-row">
                        <div style="flex:1">
                            <select id="mpSelect" class="form-select form-select-sm">
                                <option value="">-- Seleccione materia prima --</option>
                                @foreach (var m in Model.MateriasPrimas)
                                {
                                    <option value="@m.Id" data-nombre="@m.Nombre" data-unidad="@m.UnidadMedida" data-stock="@m.StockActual">
                                        @m.Nombre (@m.StockActual @m.UnidadMedida)
                                    </option>
                                }
                            </select>
                        </div>
                        <div style="width:110px">
                            <input type="number" id="mpCantidad" class="form-control form-control-sm" placeholder="Cantidad" min="0.001" step="0.001" />
                        </div>
                        <button type="button" class="btn-agregar" onclick="agregarMP()">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                            Agregar
                        </button>
                    </div>
                    <table class="chips-table">
                        <thead>
                            <tr>
                                <th>Materia Prima</th>
                                <th>Cantidad</th>
                                <th style="width:36px"></th>
                            </tr>
                        </thead>
                        <tbody id="mpBody">
                            <tr id="mpEmpty"><td colspan="3" class="empty-chips">Sin materias primas agregadas</td></tr>
                        </tbody>
                    </table>
                    <div id="mpHiddens"></div>
                </div>
            </div>
        </div>

        <!-- Productos generados -->
        <div class="col-md-6">
            <div class="card-clean">
                <div class="card-header-custom" style="color:#166534;">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>
                    Productos Generados
                </div>
                <div class="card-body p-3">
                    <div class="agregar-row">
                        <div style="flex:1">
                            <select id="prodSelect" class="form-select form-select-sm">
                                <option value="">-- Seleccione producto --</option>
                                @foreach (var p in Model.Productos)
                                {
                                    <option value="@p.Id" data-nombre="@p.Nombre">@p.Nombre</option>
                                }
                            </select>
                        </div>
                        <div style="width:110px">
                            <input type="number" id="prodCantidad" class="form-control form-control-sm" placeholder="Cantidad" min="1" />
                        </div>
                        <button type="button" class="btn-agregar" onclick="agregarProd()">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                            Agregar
                        </button>
                    </div>
                    <table class="chips-table">
                        <thead>
                            <tr>
                                <th>Producto</th>
                                <th>Cantidad</th>
                                <th style="width:36px"></th>
                            </tr>
                        </thead>
                        <tbody id="prodBody">
                            <tr id="prodEmpty"><td colspan="3" class="empty-chips">Sin productos agregados</td></tr>
                        </tbody>
                    </table>
                    <div id="prodHiddens"></div>
                </div>
            </div>
        </div>
    </div>

    <!-- Acciones -->
    <div class="d-flex justify-content-between align-items-center mt-3 pt-3" style="border-top:1px solid var(--border)">
        <small class="text-muted">Debes agregar al menos una materia prima y un producto.</small>
        <div class="d-flex gap-2">
            <a asp-page="Index" class="btn-back">Cancelar</a>
            <button type="submit" class="btn-save" id="btnGuardar" disabled>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                Registrar Lote
            </button>
        </div>
    </div>
</form>

@section Scripts {
<script>
    let mps = [], prods = [];

    // ── Materias Primas ──
    function agregarMP() {
        const sel = document.getElementById('mpSelect');
        const opt = sel.options[sel.selectedIndex];
        if (!opt.value) { alert('Seleccione una materia prima'); return; }
        const cantidad = parseFloat(document.getElementById('mpCantidad').value);
        const stock    = parseFloat(opt.dataset.stock);
        if (!cantidad || cantidad <= 0) { alert('Ingrese una cantidad válida'); return; }
        if (cantidad > stock) { alert(`Stock insuficiente. Disponible: ${stock} ${opt.dataset.unidad}`); return; }
        if (mps.find(m => m.id == opt.value)) { alert('Ya está en la lista'); return; }
        mps.push({ id: opt.value, nombre: opt.dataset.nombre, unidad: opt.dataset.unidad, cantidad });
        renderMP();
        sel.value = ''; document.getElementById('mpCantidad').value = '';
    }

    function eliminarMP(i) { mps.splice(i, 1); renderMP(); }

    function renderMP() {
        const tbody = document.getElementById('mpBody');
        const empty = document.getElementById('mpEmpty');
        tbody.innerHTML = '';
        if (mps.length === 0) {
            tbody.appendChild(empty);
            empty.style.display = '';
        } else {
            mps.forEach((m, i) => {
                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td><span class="chip-mp">${m.nombre}</span></td>
                    <td>${m.cantidad} <span style="font-size:11px;color:var(--muted)">${m.unidad}</span></td>
                    <td><button type="button" class="btn-remove" onclick="eliminarMP(${i})">✕</button></td>`;
                tbody.appendChild(tr);
            });
        }
        const h = document.getElementById('mpHiddens');
        h.innerHTML = '';
        mps.forEach((m, i) => {
            h.innerHTML += `<input type="hidden" name="MateriasUsadas[${i}].MateriaPrimaId" value="${m.id}" />
                            <input type="hidden" name="MateriasUsadas[${i}].CantidadUsada" value="${m.cantidad}" />`;
        });
        validarBoton();
    }

    // ── Productos ──
    function agregarProd() {
        const sel = document.getElementById('prodSelect');
        const opt = sel.options[sel.selectedIndex];
        if (!opt.value) { alert('Seleccione un producto'); return; }
        const cantidad = parseInt(document.getElementById('prodCantidad').value);
        if (!cantidad || cantidad < 1) { alert('Ingrese una cantidad válida'); return; }
        if (prods.find(p => p.id == opt.value)) { alert('Ya está en la lista'); return; }
        prods.push({ id: opt.value, nombre: opt.dataset.nombre, cantidad });
        renderProd();
        sel.value = ''; document.getElementById('prodCantidad').value = '';
    }

    function eliminarProd(i) { prods.splice(i, 1); renderProd(); }

    function renderProd() {
        const tbody = document.getElementById('prodBody');
        const empty = document.getElementById('prodEmpty');
        tbody.innerHTML = '';
        if (prods.length === 0) {
            tbody.appendChild(empty);
            empty.style.display = '';
        } else {
            prods.forEach((p, i) => {
                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td><span class="chip-prod">${p.nombre}</span></td>
                    <td>${p.cantidad} <span style="font-size:11px;color:var(--muted)">unidades</span></td>
                    <td><button type="button" class="btn-remove" onclick="eliminarProd(${i})">✕</button></td>`;
                tbody.appendChild(tr);
            });
        }
        const h = document.getElementById('prodHiddens');
        h.innerHTML = '';
        prods.forEach((p, i) => {
            h.innerHTML += `<input type="hidden" name="ProductosGenerados[${i}].ProductoId" value="${p.id}" />
                            <input type="hidden" name="ProductosGenerados[${i}].CantidadProducida" value="${p.cantidad}" />`;
        });
        validarBoton();
    }

    function validarBoton() {
        document.getElementById('btnGuardar').disabled = mps.length === 0 || prods.length === 0;
    }
</script>
}