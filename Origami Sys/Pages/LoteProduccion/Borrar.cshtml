@page "{id:int}"
@model Origami_Sys.Pages.LoteProduccion.BorrarModel
@{
    ViewData["Title"] = "Anular Lote";
    ViewData["Modulo"] = "Inventario";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0">Anular Lote de Producción</h5>
    <a asp-page="Index" class="btn btn-sm btn-outline-secondary">← Volver</a>
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body">
        <p class="text-danger">⚠ Esta acción revertirá el consumo de materias primas y descontará el stock de los productos generados.</p>
        <p><strong>N° Lote:</strong> @Model.Lote.NumeroLote</p>
        <p><strong>Fecha:</strong> @Model.Lote.Fecha.ToString("dd/MM/yyyy")</p>
    </div>
</div>

<form method="post">
    <input type="hidden" asp-for="Lote.Id" />
    <button type="submit" class="btn btn-danger">Anular Lote</button>
    <a asp-page="Index" class="btn btn-secondary">Cancelar</a>
</form>