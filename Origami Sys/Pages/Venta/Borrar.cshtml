@page "{id:int}"
@model Origami_Sys.Pages.Venta.BorrarModel
@{
    ViewData["Title"] = "Anular Venta";
    ViewData["Modulo"] = "Ventas";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0">Anular Venta</h5>
    <a asp-page="Index" class="btn btn-sm btn-outline-secondary">← Volver</a>
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body">
        <p class="text-danger">⚠ Esta acción anulará la venta y devolverá el stock de los productos.</p>
        <p><strong>Factura:</strong> @Model.Venta.NumeroFactura</p>
        <p><strong>Cliente:</strong> @Model.Venta.ClienteNombre</p>
        <p><strong>Fecha:</strong> @Model.Venta.Fecha.ToString("dd/MM/yyyy HH:mm")</p>
        <p><strong>Total:</strong> @Model.Venta.Total.ToString("C")</p>
    </div>
</div>

<form method="post">
    <input type="hidden" asp-for="Venta.Id" />
    <button type="submit" class="btn btn-danger">Anular Venta</button>
    <a asp-page="Index" class="btn btn-secondary">Cancelar</a>
</form>