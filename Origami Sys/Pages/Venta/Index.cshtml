@page
@model Origami_Sys.Pages.Venta.IndexModel
@{
    ViewData["Title"] = "Ventas";
    ViewData["Modulo"] = "Ventas";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0">Historial de Ventas</h5>
    <a class="btn btn-sm btn-success" asp-page="Crear">+ Nueva Venta</a>
</div>

<!-- Resumen -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <p class="text-muted small mb-1">Ventas hoy</p>
                <h4 class="mb-0">@Model.VentasHoy</h4>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <p class="text-muted small mb-1">Total hoy</p>
                <h4 class="text-success mb-0">@Model.TotalHoy.ToString("C")</h4>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <p class="text-muted small mb-1">Total del mes</p>
                <h4 class="text-success mb-0">@Model.TotalMes.ToString("C")</h4>
            </div>
        </div>
    </div>
</div>

<table class="table table-sm table-striped">
    <thead>
        <tr>
            <th>N° Factura</th>
            <th>Fecha</th>
            <th>Cliente</th>
            <th>Empleado</th>
            <th>Total</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var v in Model.Ventas)
        {
            <tr>
                <td><strong>@v.NumeroFactura</strong></td>
                <td>@v.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                <td>@(v.ClienteNombre ?? "Cliente general")</td>
                <td>@v.Empleado?.Nombre @v.Empleado?.Apellido</td>
                <td class="text-success"><strong>@v.Total.ToString("C")</strong></td>
                <td>
                    <a class="btn btn-info btn-sm" asp-page="Detalle" asp-route-id="@v.Id">Ver</a>
                    <a class="btn btn-danger btn-sm" asp-page="Borrar" asp-route-id="@v.Id">Anular</a>
                </td>
            </tr>
        }
    </tbody>
</table>