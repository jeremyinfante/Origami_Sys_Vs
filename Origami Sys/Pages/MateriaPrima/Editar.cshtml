@page "{id:int}"
@model Origami_Sys.Pages.MateriaPrima.EditarModel
@{
    ViewData["Title"] = "Editar Materia Prima";
    ViewData["Modulo"] = "Inventario";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0">Editar Materia Prima</h5>
    <a asp-page="Index" class="btn btn-sm btn-outline-secondary">← Volver</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <form method="post">
            <input type="hidden" asp-for="MateriaPrima.Id" />
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="MateriaPrima.Nombre" class="form-label">Nombre</label>
                    <input asp-for="MateriaPrima.Nombre" class="form-control" />
                    <span asp-validation-for="MateriaPrima.Nombre" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="MateriaPrima.UnidadMedida" class="form-label">Unidad de Medida</label>
                    <select asp-for="MateriaPrima.UnidadMedida" class="form-select">
                        <option value="kg">Kilogramos (kg)</option>
                        <option value="g">Gramos (g)</option>
                        <option value="L">Litros (L)</option>
                        <option value="ml">Mililitros (ml)</option>
                        <option value="unidad">Unidad</option>
                        <option value="oz">Onzas (oz)</option>
                    </select>
                </div>
                <div class="col-md-12 mb-3">
                    <label asp-for="MateriaPrima.Descripcion" class="form-label">Descripción</label>
                    <textarea asp-for="MateriaPrima.Descripcion" class="form-control" rows="2"></textarea>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="MateriaPrima.StockMinimo" class="form-label">Stock Mínimo</label>
                    <input asp-for="MateriaPrima.StockMinimo" class="form-control" />
                    <span asp-validation-for="MateriaPrima.StockMinimo" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Stock Actual</label>
                    <input asp-for="MateriaPrima.StockActual" class="form-control" readonly />
                    <small class="text-muted">El stock se actualiza mediante compras y lotes de producción.</small>
                </div>
            </div>
            <button type="submit" class="btn btn-primary">Actualizar</button>
            <a asp-page="Index" class="btn btn-secondary">Cancelar</a>
        </form>
    </div>
</div>