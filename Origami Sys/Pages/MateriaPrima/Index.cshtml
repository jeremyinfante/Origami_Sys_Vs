@page
@model Origami_Sys.Pages.MateriaPrima.IndexModel
@{
    ViewData["Title"] = "Materias Primas";
    ViewData["Modulo"] = "Inventario";
}

<style>
    :root{--g-dark:#1a4332;--g-bright:#10b981;--danger:#be123c;--border:#e5e7eb;--text:#1f2937;--muted:#6b7280;--bg:#f9fafb;}
    .toolbar{display:flex;gap:10px;align-items:center;flex-wrap:wrap;background:white;border:1px solid var(--border);border-radius:10px;padding:12px 16px;margin-bottom:16px;box-shadow:0 1px 3px rgba(0,0,0,.04);}
    .search-wrap{position:relative;flex:1;min-width:180px;}
    .search-wrap svg{position:absolute;left:10px;top:50%;transform:translateY(-50%);color:var(--muted);pointer-events:none;}
    .search-wrap input{width:100%;padding:7px 12px 7px 34px;border:1px solid var(--border);border-radius:7px;font-size:13px;outline:none;transition:border-color .15s,box-shadow .15s;}
    .search-wrap input:focus{border-color:var(--g-bright);box-shadow:0 0 0 3px rgba(16,185,129,.1);}
    .toolbar select{padding:7px 10px;border:1px solid var(--border);border-radius:7px;font-size:13px;color:var(--text);background:white;cursor:pointer;outline:none;}
    .toolbar select:focus{border-color:var(--g-bright);box-shadow:0 0 0 3px rgba(16,185,129,.1);}
    .btn-nuevo{display:inline-flex;align-items:center;gap:6px;background:var(--g-dark);color:white;border:none;padding:7px 16px;border-radius:7px;font-size:13px;font-weight:600;text-decoration:none;white-space:nowrap;transition:background .15s,transform .1s;}
    .btn-nuevo:hover{background:#2d5a3d;color:white;transform:translateY(-1px);}
    .bulk-bar{display:none;align-items:center;gap:10px;background:#fff7ed;border:1px solid #fed7aa;border-radius:8px;padding:10px 16px;margin-bottom:12px;font-size:13px;color:#92400e;}
    .bulk-bar.visible{display:flex;}
    .btn-bulk-delete{display:inline-flex;align-items:center;gap:6px;background:var(--danger);color:white;border:none;padding:5px 14px;border-radius:6px;font-size:12px;font-weight:600;cursor:pointer;}
    .btn-bulk-delete:hover{background:#9f1239;}
    .tabla-wrap{background:white;border:1px solid var(--border);border-radius:10px;overflow:hidden;box-shadow:0 1px 3px rgba(0,0,0,.04);}
    .tabla-wrap table{width:100%;border-collapse:collapse;font-size:13px;}
    .tabla-wrap thead th{background:var(--bg);padding:10px 14px;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--muted);border-bottom:1px solid var(--border);white-space:nowrap;}
    .tabla-wrap tbody tr{border-bottom:1px solid #f3f4f6;transition:background .1s;}
    .tabla-wrap tbody tr:last-child{border-bottom:none;}
    .tabla-wrap tbody tr:hover{background:#f0fdf4;}
    .tabla-wrap tbody tr.selected{background:#ecfdf5;}
    .tabla-wrap td{padding:10px 14px;color:var(--text);vertical-align:middle;}
    .nombre-bold{font-weight:600;color:var(--g-dark);}
    .desc-muted{font-size:12px;color:var(--muted);}
    .unidad-badge{background:#f3f4f6;color:var(--muted);font-size:11px;font-family:monospace;padding:2px 7px;border-radius:5px;}
    .stock-val{font-weight:600;}
    .badge-ok{background:#dcfce7;color:#166534;font-size:11px;font-weight:600;padding:2px 8px;border-radius:20px;}
    .badge-warn{background:#fee2e2;color:#991b1b;font-size:11px;font-weight:600;padding:2px 8px;border-radius:20px;}
    .acciones{display:flex;gap:5px;white-space:nowrap;}
    .btn-ac{display:inline-flex;align-items:center;gap:3px;font-size:11px;font-weight:600;padding:4px 9px;border-radius:5px;text-decoration:none;transition:opacity .15s,transform .1s;border:none;cursor:pointer;background:none;}
    .btn-ac:hover{opacity:.8;transform:translateY(-1px);}
    .ac-edit{background:#e8f0fe!important;color:#1a56db;}
    .ac-del{background:#fde8e8!important;color:#c81e1e;}
    .result-count{font-size:12px;color:var(--muted);margin-bottom:8px;padding-left:2px;}
    .empty-state{text-align:center;padding:48px 20px;color:var(--muted);}
    .empty-state p{font-size:14px;margin:0;}
    /* Barra de stock mini */
    .stock-bar-wrap{background:#f3f4f6;border-radius:99px;height:4px;margin-top:4px;width:80px;overflow:hidden;}
    .stock-bar-fill{height:100%;border-radius:99px;}
</style>

<!-- Toolbar -->
<div class="toolbar">
    <div class="search-wrap">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
        <input type="text" id="buscador" placeholder="Buscar por nombre o descripción..." autocomplete="off" />
    </div>

    <select id="filtroEstado">
        <option value="">Todos los estados</option>
        <option value="ok">Stock OK</option>
        <option value="bajo">Bajo stock</option>
    </select>

    <select id="filtroUnidad">
        <option value="">Todas las unidades</option>
        @foreach (var u in Model.Unidades)
        {
            <option value="@u">@u</option>
        }
    </select>

    <select id="ordenar">
        <option value="">Ordenar por...</option>
        <option value="nombre-asc">Nombre A→Z</option>
        <option value="nombre-desc">Nombre Z→A</option>
        <option value="stock-asc">Stock ↑</option>
        <option value="stock-desc">Stock ↓</option>
    </select>

    <a class="btn-nuevo" asp-page="Crear">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
        Nueva Materia Prima
    </a>
</div>

<form method="post" asp-page-handler="BorrarSeleccion" id="formBulk">
    <div class="bulk-bar" id="bulkBar">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
        </svg>
        <span id="bulkCount">0</span> materia(s) seleccionada(s)
        <button type="submit" class="btn-bulk-delete" onclick="return confirm('¿Eliminar las materias primas seleccionadas?')">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="3 6 5 6 21 6"/>
                <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
            </svg>
            Eliminar selección
        </button>
        <button type="button" class="btn-ac ac-edit" onclick="deseleccionarTodo()">Cancelar</button>
    </div>

    <div class="result-count" id="resultCount"></div>

    <div class="tabla-wrap">
        <table>
            <thead>
                <tr>
                    <th style="width:36px"><input type="checkbox" id="selectAll" /></th>
                    <th>Nombre</th>
                    <th>Descripción</th>
                    <th>Unidad</th>
                    <th>Stock Actual</th>
                    <th>Stock Mínimo</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody id="tbody">
                @foreach (var m in Model.MateriasPrimas)
                {
                    var pct = m.StockMinimo > 0 ? Math.Min(100, (int)((double)m.StockActual / (double)m.StockMinimo * 100)) : 100;
                    var barColor = m.StockActual <= m.StockMinimo ? "#ef4444" : "#10b981";
                    <tr data-nombre="@m.Nombre.ToLower()"
                        data-desc="@(m.Descripcion?.ToLower() ?? "")"
                        data-unidad="@m.UnidadMedida"
                        data-stock="@m.StockActual"
                        data-estado="@(m.StockActual <= m.StockMinimo ? "bajo" : "ok")">
                        <td><input type="checkbox" name="ids" value="@m.Id" class="row-check" /></td>
                        <td><span class="nombre-bold">@m.Nombre</span></td>
                        <td><span class="desc-muted">@(m.Descripcion ?? "—")</span></td>
                        <td><span class="unidad-badge">@m.UnidadMedida</span></td>
                        <td>
                            <span class="stock-val" style="color:@barColor">@m.StockActual</span>
                            <div class="stock-bar-wrap">
                                <div class="stock-bar-fill" style="width:@(Math.Min(pct,100))%;background:@barColor"></div>
                            </div>
                        </td>
                        <td>@m.StockMinimo <span style="font-size:11px;color:var(--muted)">@m.UnidadMedida</span></td>
                        <td>
                            @if (m.StockActual <= m.StockMinimo)
                            {
                                <span class="badge-warn">⚠ Reabastecer</span>
                            }
                            else
                            {
                                <span class="badge-ok">OK</span>
                            }
                        </td>
                        <td>
                            <div class="acciones">
                                <a class="btn-ac ac-edit" asp-page="Editar" asp-route-id="@m.Id">
                                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                    Editar
                                </a>
                                <button type="button" class="btn-ac ac-del" onclick="abrirModal(@m.Id, '@Html.Raw(m.Nombre.Replace("'", "\\'"))')">
                                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                                    Eliminar
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <div class="empty-state" id="emptyState" style="display:none">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="opacity:.3;margin-bottom:12px;display:block;margin-inline:auto">
                <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
            </svg>
            <p>No se encontraron materias primas.</p>
        </div>
    </div>
</form>

<!-- Modal eliminar -->
<div id="modalEliminar" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:1000;align-items:center;justify-content:center;">
    <div style="background:white;border-radius:14px;width:100%;max-width:400px;overflow:hidden;box-shadow:0 20px 60px rgba(0,0,0,.2);">
        <div style="background:#be123c;padding:16px 20px;display:flex;align-items:center;gap:10px;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
                <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                <line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
            </svg>
            <div style="color:white;font-weight:700;font-size:14px;">Confirmar eliminación</div>
        </div>
        <div style="padding:20px;">
            <p style="font-size:13px;color:#374151;margin:0 0 16px 0;">
                ¿Eliminar <strong id="modalNombre"></strong>? Esta acción no se puede deshacer.
            </p>
            <div style="display:flex;gap:8px;justify-content:flex-end;">
                <button onclick="cerrarModal()" style="background:white;border:1px solid #e5e7eb;color:#6b7280;padding:7px 16px;border-radius:7px;font-size:12px;cursor:pointer;">Cancelar</button>
                <form method="post" asp-page-handler="Eliminar" id="formEliminar" style="margin:0;">
                    <input type="hidden" name="id" id="modalId" />
                    <button type="submit" style="background:#be123c;color:white;border:none;padding:7px 16px;border-radius:7px;font-size:12px;font-weight:600;cursor:pointer;">Eliminar</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const filas = () => [...document.querySelectorAll('#tbody tr')];

    function aplicar() {
        const q      = document.getElementById('buscador').value.toLowerCase().trim();
        const estado = document.getElementById('filtroEstado').value;
        const unidad = document.getElementById('filtroUnidad').value;
        const orden  = document.getElementById('ordenar').value;

        let visibles = filas().filter(tr => {
            const matchQ      = !q      || tr.dataset.nombre.includes(q) || tr.dataset.desc.includes(q);
            const matchEstado = !estado || tr.dataset.estado === estado;
            const matchUnidad = !unidad || tr.dataset.unidad === unidad;
            return matchQ && matchEstado && matchUnidad;
        });

        filas().forEach(tr => tr.style.display = 'none');

        if (orden) {
            const [campo, dir] = orden.split('-');
            visibles.sort((a, b) => {
                let va = campo === 'stock' ? parseFloat(a.dataset.stock) : a.dataset.nombre;
                let vb = campo === 'stock' ? parseFloat(b.dataset.stock) : b.dataset.nombre;
                if (typeof va === 'string') return dir === 'asc' ? va.localeCompare(vb) : vb.localeCompare(va);
                return dir === 'asc' ? va - vb : vb - va;
            });
            const tbody = document.getElementById('tbody');
            visibles.forEach(tr => tbody.appendChild(tr));
        }

        visibles.forEach(tr => tr.style.display = '');
        document.getElementById('emptyState').style.display = visibles.length === 0 ? '' : 'none';

        const total = filas().length;
        document.getElementById('resultCount').textContent =
            visibles.length === total ? `${total} materia(s) prima(s)` : `Mostrando ${visibles.length} de ${total}`;
    }

    ['buscador','filtroEstado','filtroUnidad','ordenar'].forEach(id =>
        document.getElementById(id).addEventListener('input', aplicar)
    );

    function actualizarBulk() {
        const checked = document.querySelectorAll('.row-check:checked').length;
        document.getElementById('bulkBar').classList.toggle('visible', checked > 0);
        document.getElementById('bulkCount').textContent = checked;
        document.querySelectorAll('.row-check').forEach(cb => cb.closest('tr').classList.toggle('selected', cb.checked));
    }

    document.getElementById('selectAll').addEventListener('change', function() {
        [...document.querySelectorAll('#tbody tr')]
            .filter(tr => tr.style.display !== 'none')
            .forEach(tr => tr.querySelector('.row-check').checked = this.checked);
        actualizarBulk();
    });

    document.querySelectorAll('.row-check').forEach(cb => cb.addEventListener('change', actualizarBulk));

    function deseleccionarTodo() {
        document.querySelectorAll('.row-check').forEach(cb => cb.checked = false);
        document.getElementById('selectAll').checked = false;
        actualizarBulk();
    }

    const modal = document.getElementById('modalEliminar');

    function abrirModal(id, nombre) {
        document.getElementById('modalNombre').textContent = nombre;
        document.getElementById('modalId').value = id;
        modal.style.display = 'flex';
        document.body.style.overflow = 'hidden';
    }
    function cerrarModal() {
        modal.style.display = 'none';
        document.body.style.overflow = '';
    }
    modal.addEventListener('mousedown', e => { if (e.target === modal) cerrarModal(); });
    document.addEventListener('keydown', e => { if (e.key === 'Escape') cerrarModal(); });

    aplicar();
</script>
}