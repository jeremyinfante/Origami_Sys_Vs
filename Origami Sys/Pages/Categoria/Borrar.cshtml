@page "{id:int}"
@model Origami_Sys.Pages.Categoria.BorrarModel
@{
    ViewData["Title"] = "Eliminar Categoría";
}

<h1>Eliminar Categoría</h1>
<p>¿Está seguro de que desea eliminar esta categoría?</p>

<div class="card mb-3">
    <div class="card-body">
        <h5 class="card-title">@Model.Categoria.Nombre</h5>
        <p>@Model.Categoria.Descripcion</p>
    </div>
</div>

<form method="post">
    <input type="hidden" asp-for="Categoria.Id" />
    <button type="submit" class="btn btn-danger">Eliminar</button>
    <a asp-page="Index" class="btn btn-secondary">Cancelar</a>
</form>