@page "{id:int}"
@model Origami_Sys.Pages.Empleado.BorrarModel
@{
    ViewData["Title"] = "Eliminar Empleado";
    ViewData["Modulo"] = "RRHH";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0">Eliminar Empleado</h5>
    <a asp-page="Index" class="btn btn-sm btn-outline-secondary">← Volver</a>
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body">
        <p>¿Está seguro de que desea eliminar este empleado?</p>
        <p><strong>Nombre:</strong> @Model.Empleado.Nombre @Model.Empleado.Apellido</p>
        <p><strong>Cédula:</strong> @Model.Empleado.Cedula</p>
        <p><strong>Salario:</strong> @Model.Empleado.SalarioBase.ToString("C")</p>
    </div>
</div>

<form method="post">
    <input type="hidden" asp-for="Empleado.Id" />
    <button type="submit" class="btn btn-danger">Eliminar</button>
    <a asp-page="Index" class="btn btn-secondary">Cancelar</a>
</form>