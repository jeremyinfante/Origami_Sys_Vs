@page
@model Origami_Sys.Pages.Empleado.CrearModel
@{
    ViewData["Title"] = "Nuevo Empleado";
    ViewData["Modulo"] = "RRHH";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0">Nuevo Empleado</h5>
    <a asp-page="Index" class="btn btn-sm btn-outline-secondary">← Volver</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <form method="post">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Empleado.Cedula" class="form-label">Cédula</label>
                    <input asp-for="Empleado.Cedula" class="form-control" />
                    <span asp-validation-for="Empleado.Cedula" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Empleado.Telefono" class="form-label">Teléfono</label>
                    <input asp-for="Empleado.Telefono" class="form-control" />
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Empleado.Nombre" class="form-label">Nombre</label>
                    <input asp-for="Empleado.Nombre" class="form-control" />
                    <span asp-validation-for="Empleado.Nombre" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Empleado.Apellido" class="form-label">Apellido</label>
                    <input asp-for="Empleado.Apellido" class="form-control" />
                    <span asp-validation-for="Empleado.Apellido" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Empleado.SalarioBase" class="form-label">Salario Base</label>
                    <input asp-for="Empleado.SalarioBase" class="form-control" />
                    <span asp-validation-for="Empleado.SalarioBase" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3 d-flex align-items-end">
                    <div class="form-check mb-2">
                        <input asp-for="Empleado.Activo" class="form-check-input" type="checkbox" />
                        <label asp-for="Empleado.Activo" class="form-check-label">Activo</label>
                    </div>
                </div>
            </div>
            <button type="submit" class="btn btn-success">Guardar</button>
            <a asp-page="Index" class="btn btn-secondary">Cancelar</a>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}