@page
@model Origami_Sys.Pages.Empleado.CrearModel
@{
    ViewData["Title"] = "Nuevo Empleado";
    ViewData["Modulo"] = "RRHH";
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>
    :root {
        --brand-green: #1a4332;
        --brand-green-bright: #10b981;
        --brand-green-light: #f0fdf4;
        --border-color: #e5e7eb;
        --text-main: #1f2937;
        --text-muted: #6b7280;
        --bg-body: #f3f4f6;
    }

    body {
        background-color: var(--bg-body);
        font-family: 'Inter', sans-serif;
        color: var(--text-main);
        font-size: 14px;
    }

    .main-wrapper-fluid {
        width: 100%;
        padding: 1.5rem 2rem;
    }

    /* Header */
    .header-minimal {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
    }

    .header-minimal h1 {
        font-size: 1.5rem;
        font-weight: 700;
        margin: 0;
        color: var(--brand-green);
        letter-spacing: -0.02em;
    }

    .breadcrumb-text {
        font-size: 11px;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 4px;
    }

    /* Tarjeta Principal */
    .card-clean {
        background: #ffffff;
        border: 1px solid var(--border-color);
        border-radius: 12px;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
    }

    /* Seccionado */
    .form-section-label {
        font-size: 11px;
        font-weight: 700;
        color: var(--brand-green-bright);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin: 1.5rem 0 1rem 0;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .form-section-label::after {
        content: "";
        flex: 1;
        height: 1px;
        background: #f1f5f9;
    }

    .form-label {
        font-weight: 500;
        font-size: 13px;
        margin-bottom: 6px;
        color: #374151;
    }

    .form-control, .form-select {
        font-size: 14px;
        padding: 0.6rem 0.8rem;
        border-radius: 8px;
        border: 1px solid var(--border-color);
        transition: all 0.2s ease;
    }

    .form-control:focus, .form-select:focus {
        border-color: var(--brand-green-bright);
        box-shadow: 0 0 0 4px rgba(16, 185, 129, 0.1);
        outline: none;
    }

    /* Checkbox personalizado */
    .checkbox-wrapper {
        background-color: #fafafa;
        border-radius: 10px;
        padding: 1rem 1.25rem;
        border: 1px solid #f1f5f9;
        display: flex;
        align-items: center;
        height: 100%;
    }

    .form-check-input {
        width: 1.2em;
        height: 1.2em;
        margin-right: 0.5rem;
        border: 2px solid var(--border-color);
        cursor: pointer;
    }

    .form-check-input:checked {
        background-color: var(--brand-green-bright);
        border-color: var(--brand-green-bright);
    }

    .form-check-label {
        font-weight: 500;
        font-size: 14px;
        cursor: pointer;
        user-select: none;
    }

    /* Input group para salario */
    .input-group-text {
        background-color: #f9fafb;
        border: 1px solid var(--border-color);
        font-weight: 600;
        color: var(--text-muted);
    }

    /* Estado activo visual */
    .status-indicator {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        margin-left: 8px;
    }

    .status-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background-color: #10b981;
        animation: pulse 2s infinite;
    }

    @@keyframes pulse {
        0% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.4); }
        70% { box-shadow: 0 0 0 6px rgba(16, 185, 129, 0); }
        100% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0); }
    }

    /* Botones */
    .btn-save {
        background-color: var(--brand-green-bright);
        color: white;
        border: none;
        padding: 0.6rem 2rem;
        font-size: 14px;
        font-weight: 600;
        border-radius: 8px;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .btn-save:hover {
        background-color: #059669;
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(16, 185, 129, 0.2);
        color: white;
    }

    .btn-cancel {
        background-color: #fff;
        color: var(--text-muted);
        border: 1px solid var(--border-color);
        padding: 0.6rem 1.5rem;
        font-size: 14px;
        border-radius: 8px;
        transition: all 0.2s;
    }

    .btn-cancel:hover {
        background-color: #f9fafb;
        border-color: #d1d5db;
        color: var(--text-main);
    }
</style>

<div class="main-wrapper-fluid">
    <!-- Header -->
    <div class="header-minimal">
        <div>
            <div class="breadcrumb-text">@ViewData["Modulo"] / Personal</div>
            <h1>Registrar Nuevo Empleado</h1>
        </div>
        <a asp-page="Index" class="btn-cancel text-decoration-none d-flex align-items-center gap-2">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6" /></svg>
            Volver al listado
        </a>
    </div>

    <!-- Card Formulario -->
    <div class="card-clean">
        <div class="card-body p-4 p-lg-5">
            <form method="post">

                <!-- SECCIÓN 1: IDENTIFICACIÓN -->
                <div class="form-section-label">Identificación Personal</div>
                <div class="row g-4 mb-4">
                    <div class="col-xl-4 col-md-6">
                        <label asp-for="Empleado.Cedula" class="form-label">Cédula de Identidad <span class="text-danger">*</span></label>
                        <input asp-for="Empleado.Cedula" class="form-control" placeholder="Ej: 001-1234567-8" />
                        <span asp-validation-for="Empleado.Cedula" class="text-danger" style="font-size:11px"></span>
                    </div>
                    <div class="col-xl-4 col-md-6">
                        <label asp-for="Empleado.Nombre" class="form-label">Nombre(s) <span class="text-danger">*</span></label>
                        <input asp-for="Empleado.Nombre" class="form-control" placeholder="Ej: Juan Carlos" />
                        <span asp-validation-for="Empleado.Nombre" class="text-danger" style="font-size:11px"></span>
                    </div>
                    <div class="col-xl-4 col-md-6">
                        <label asp-for="Empleado.Apellido" class="form-label">Apellido(s) <span class="text-danger">*</span></label>
                        <input asp-for="Empleado.Apellido" class="form-control" placeholder="Ej: Pérez García" />
                        <span asp-validation-for="Empleado.Apellido" class="text-danger" style="font-size:11px"></span>
                    </div>
                </div>

                <!-- SECCIÓN 2: CONTACTO Y CONTRATACIÓN -->
                <div class="form-section-label">Información de Contacto y Contratación</div>
                <div class="row g-4 mb-4">
                    <div class="col-xl-4 col-md-6">
                        <label asp-for="Empleado.Telefono" class="form-label">Teléfono de Contacto</label>
                        <div class="input-group">
                            <span class="input-group-text">
                                <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M3.654 1.328a.678.678 0 0 0-1.015-.063L1.605 2.3c-.483.484-.661 1.169-.45 1.77a17.568 17.568 0 0 0 4.168 6.608 17.569 17.569 0 0 0 6.608 4.168c.601.211 1.286.033 1.77-.45l1.034-1.034a.678.678 0 0 0-.063-1.015l-2.307-1.794a.678.678 0 0 0-.58-.122l-2.19.547a1.745 1.745 0 0 1-1.657-.459L5.482 8.062a1.745 1.745 0 0 1-.46-1.657l.548-2.19a.678.678 0 0 0-.122-.58L3.654 1.328z"/></svg>
                            </span>
                            <input asp-for="Empleado.Telefono" class="form-control" placeholder="Ej: 809-555-0100" />
                        </div>
                    </div>
                    <div class="col-xl-4 col-md-6">
                        <label asp-for="Empleado.SalarioBase" class="form-label">Salario Base <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input asp-for="Empleado.SalarioBase" class="form-control fw-bold" placeholder="0.00" />
                        </div>
                        <span asp-validation-for="Empleado.SalarioBase" class="text-danger" style="font-size:11px"></span>
                    </div>
                    <div class="col-xl-4 col-md-6">
                        <label class="form-label">Estado del Empleado</label>
                        <div class="checkbox-wrapper">
                            <input asp-for="Empleado.Activo" class="form-check-input" type="checkbox" id="checkActivo" />

                            <span class="status-indicator">
                                <span class="status-dot" id="statusDot"></span>
                                <small id="statusText" style="color: #10b981; font-weight: 600;">Disponible</small>
                            </span>
                        </div>
                    </div>
                </div>

                <!-- SECCIÓN 3: RESUMEN RÁPIDO -->
                <div class="form-section-label">Resumen del Registro</div>
                <div class="row g-4 mb-5">
                    <div class="col-12">
                        <div class="p-4" style="background-color: #f0fdf4; border-radius: 12px; border: 1px solid #d1fae5;">
                            <div class="row">
                                <div class="col-md-4 mb-2">
                                    <small class="text-muted" style="font-size: 11px; text-transform: uppercase; font-weight: 600;">Nombre Completo</small>
                                    <div class="fw-bold" id="resumenNombre">—</div>
                                </div>
                                <div class="col-md-4 mb-2">
                                    <small class="text-muted" style="font-size: 11px; text-transform: uppercase; font-weight: 600;">Salario Mensual</small>
                                    <div class="fw-bold" id="resumenSalario">—</div>
                                </div>
                                <div class="col-md-4 mb-2">
                                    <small class="text-muted" style="font-size: 11px; text-transform: uppercase; font-weight: 600;">Salario Anual Estimado</small>
                                    <div class="fw-bold text-success" id="resumenAnual">—</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ACCIONES -->
                <div class="d-flex justify-content-between align-items-center pt-4 border-top">
                    <span class="text-muted" style="font-size: 13px;">Los campos marcados con <span class="text-danger">*</span> son obligatorios</span>
                    <div class="d-flex gap-3">
                        <a asp-page="Index" class="btn-cancel text-decoration-none">Cancelar</a>
                        <button type="submit" class="btn-save">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="8.5" cy="7" r="4" /><polyline points="17 11 19 13 23 9" /></svg>
                            Guardar Empleado
                        </button>
                    </div>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    
    <script>
        // Actualizar el resumen en tiempo real
        document.addEventListener('DOMContentLoaded', function() {
            const inputNombre = document.querySelector('#Empleado_Nombre');
            const inputApellido = document.querySelector('#Empleado_Apellido');
            const inputSalario = document.querySelector('#Empleado_SalarioBase');
            const checkActivo = document.querySelector('#checkActivo');
            
            function actualizarResumen() {
                const nombre = inputNombre?.value || '';
                const apellido = inputApellido?.value || '';
                const nombreCompleto = [nombre, apellido].filter(Boolean).join(' ') || '—';
                
                const salario = parseFloat(inputSalario?.value) || 0;
                const salarioFormateado = salario > 0 ? salario.toLocaleString('es-DO', { style: 'currency', currency: 'DOP' }) : '—';
                const salarioAnual = salario > 0 ? (salario * 12).toLocaleString('es-DO', { style: 'currency', currency: 'DOP' }) : '—';
                
                document.getElementById('resumenNombre').textContent = nombreCompleto;
                document.getElementById('resumenSalario').textContent = salarioFormateado;
                document.getElementById('resumenAnual').textContent = salarioAnual;
            }
            
            // Actualizar estado visual del checkbox
            function actualizarEstado() {
                const dot = document.getElementById('statusDot');
                const text = document.getElementById('statusText');
                
                if (checkActivo.checked) {
                    dot.style.backgroundColor = '#10b981';
                    text.style.color = '#10b981';
                    text.textContent = 'Activo';
                } else {
                    dot.style.backgroundColor = '#6b7280';
                    text.style.color = '#6b7280';
                    text.textContent = 'Inactivo';
                    dot.style.animation = 'none';
                }
            }
            
            if (inputNombre) inputNombre.addEventListener('input', actualizarResumen);
            if (inputApellido) inputApellido.addEventListener('input', actualizarResumen);
            if (inputSalario) inputSalario.addEventListener('input', actualizarResumen);
            if (checkActivo) {
                checkActivo.addEventListener('change', function() {
                    actualizarEstado();
                    const dot = document.getElementById('statusDot');
                    if (this.checked) {
                        dot.style.animation = 'pulse 2s infinite';
                    }
                });
            }
            
            // Inicializar
            actualizarResumen();
            actualizarEstado();
        });
    </script>
}