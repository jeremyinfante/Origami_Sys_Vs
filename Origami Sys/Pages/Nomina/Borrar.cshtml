@page "{id:int}"
@model Origami_Sys.Pages.Nomina.BorrarModel
@{
    ViewData["Title"] = "Eliminar Registro de Nómina";
    ViewData["Modulo"] = "RRHH";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0">Eliminar Registro de Nómina</h5>
    <a asp-page="Index" class="btn btn-sm btn-outline-secondary">← Volver</a>
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body">
        <p>¿Está seguro de que desea eliminar este registro?</p>
        <p><strong>Empleado:</strong> @Model.Nomina.Empleado?.Nombre @Model.Nomina.Empleado?.Apellido</p>
        <p><strong>Período:</strong> @Model.Nomina.PeriodoInicio.ToString("dd/MM/yyyy") - @Model.Nomina.PeriodoFin.ToString("dd/MM/yyyy")</p>
        <p><strong>Salario Neto:</strong> @Model.Nomina.SalarioNeto.ToString("C")</p>
    </div>
</div>

<form method="post">
    <input type="hidden" asp-for="Nomina.Id" />
    <button type="submit" class="btn btn-danger">Eliminar</button>
    <a asp-page="Index" class="btn btn-secondary">Cancelar</a>
</form>