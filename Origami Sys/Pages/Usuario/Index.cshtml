@page
@model Origami_Sys.Pages.Usuario.IndexModel
@{
    ViewData["Title"] = "Usuarios";
    ViewData["Modulo"] = "RRHH";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0">Usuarios del sistema</h5>
    <a class="btn btn-sm btn-success" asp-page="Crear">+ Nuevo Usuario</a>
</div>

<table class="table table-striped table-sm">
    <thead>
        <tr>
            <th>Username</th>
            <th>Empleado</th>
            <th>Rol</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var u in Model.Usuarios)
        {
            <tr>
                <td>@u.Username</td>
                <td>@u.Empleado?.Nombre @u.Empleado?.Apellido</td>
                <td><span class="badge bg-secondary">@u.Rol?.Nombre</span></td>
                <td>
                    <a class="btn btn-secondary btn-sm" asp-page="Editar" asp-route-id="@u.Id">Editar</a>
                    <a class="btn btn-danger btn-sm" asp-page="Borrar" asp-route-id="@u.Id">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>