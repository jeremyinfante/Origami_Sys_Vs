@page "{id:int}"
@model Origami_Sys.Pages.Usuario.BorrarModel
@{
    ViewData["Title"] = "Eliminar Usuario";
    ViewData["Modulo"] = "RRHH";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0">Eliminar Usuario</h5>
    <a asp-page="Index" class="btn btn-sm btn-outline-secondary">← Volver</a>
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body">
        <p>¿Está seguro de que desea eliminar este usuario?</p>
        <p><strong>Username:</strong> @Model.Usuario.Username</p>
        <p><strong>Empleado:</strong> @Model.Usuario.Empleado?.Nombre @Model.Usuario.Empleado?.Apellido</p>
        <p><strong>Rol:</strong> @Model.Usuario.Rol?.Nombre</p>
    </div>
</div>

<form method="post">
    <input type="hidden" asp-for="Usuario.Id" />
    <button type="submit" class="btn btn-danger">Eliminar</button>
    <a asp-page="Index" class="btn btn-secondary">Cancelar</a>
</form>