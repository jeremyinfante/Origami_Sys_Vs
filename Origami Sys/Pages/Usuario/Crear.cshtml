@page
@model Origami_Sys.Pages.Usuario.CrearModel
@{
    ViewData["Title"] = "Nuevo Usuario";
    ViewData["Modulo"] = "RRHH";
}

<style>
    :root {
        --brand-green: #1a4332;
        --brand-green-bright: #10b981;
        --brand-green-light: #f0fdf4;
        --border-color: #e5e7eb;
        --text-main: #1f2937;
        --text-muted: #6b7280;
        --bg-body: #f3f4f6;
        --danger: #be123c;
    }

    body {
        background-color: var(--bg-body);
        color: var(--text-main);
        font-size: 14px;
    }

    .main-wrapper-fluid {
        width: 100%;
        padding: 1.5rem 2rem;
    }

    /* Header */
    .header-minimal {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
    }

    .header-minimal h1 {
        font-size: 1.5rem;
        font-weight: 700;
        margin: 0;
        color: var(--brand-green);
        letter-spacing: -0.02em;
    }

    .breadcrumb-text {
        font-size: 11px;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 4px;
    }

    /* Tarjeta Principal */
    .card-clean {
        background: #ffffff;
        border: 1px solid var(--border-color);
        border-radius: 12px;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
    }

    /* Seccionado */
    .form-section-label {
        font-size: 11px;
        font-weight: 700;
        color: var(--brand-green-bright);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin: 1.5rem 0 1rem 0;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .form-section-label::after {
        content: "";
        flex: 1;
        height: 1px;
        background: #f1f5f9;
    }

    .form-label {
        font-weight: 500;
        font-size: 13px;
        margin-bottom: 6px;
        color: #374151;
    }

    .form-control, .form-select {
        font-size: 14px;
        padding: 0.6rem 0.8rem;
        border-radius: 8px;
        border: 1px solid var(--border-color);
        transition: all 0.2s ease;
    }

    .form-control:focus, .form-select:focus {
        border-color: var(--brand-green-bright);
        box-shadow: 0 0 0 4px rgba(16, 185, 129, 0.1);
        outline: none;
    }

    /* Input group */
    .input-group-text {
        background-color: #f9fafb;
        border: 1px solid var(--border-color);
        font-weight: 600;
        color: var(--text-muted);
        font-size: 13px;
    }

    /* Password strength */
    .password-strength {
        margin-top: 6px;
        height: 4px;
        border-radius: 2px;
        background: #e5e7eb;
        overflow: hidden;
        transition: all 0.3s;
    }

    .password-strength-bar {
        height: 100%;
        border-radius: 2px;
        transition: width 0.3s, background-color 0.3s;
    }

    .strength-text {
        font-size: 11px;
        margin-top: 4px;
        font-weight: 500;
    }

    .strength-weak { color: #dc2626; }
    .strength-fair { color: #f59e0b; }
    .strength-good { color: #10b981; }
    .strength-strong { color: #059669; }

    /* Badges de rol preview */
    .badge-rol-preview {
        font-size: 11px;
        font-weight: 600;
        padding: 4px 10px;
        border-radius: 20px;
        display: inline-flex;
        align-items: center;
        gap: 4px;
    }
    .rol-admin { background: #fef3c7; color: #92400e; }
    .rol-usuario { background: #dbeafe; color: #1e40af; }
    .rol-supervisor { background: #ede9fe; color: #5b21b6; }
    .rol-otro { background: #f3f4f6; color: #374151; }

    /* Resumen */
    .resumen-card {
        background: linear-gradient(135deg, #f0fdf4 0%, #ecfdf5 100%);
        border: 1px solid #d1fae5;
        border-radius: 12px;
        padding: 1.5rem;
        margin-top: 1.5rem;
    }

    .resumen-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 1.5rem;
    }

    .resumen-item {
        text-align: center;
    }

    .resumen-item .label {
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--text-muted);
        margin-bottom: 4px;
    }

    .resumen-item .valor {
        font-size: 16px;
        font-weight: 600;
        color: var(--brand-green);
    }

    .resumen-item .valor.username-preview {
        font-family: 'SF Mono', 'Fira Code', monospace;
        color: var(--brand-green);
    }

    /* Toggle mostrar contraseña */
    .password-toggle {
        cursor: pointer;
        padding: 0.6rem 0.8rem;
        border: 1px solid var(--border-color);
        border-left: none;
        background: white;
        border-radius: 0 8px 8px 0;
        color: var(--text-muted);
        transition: color 0.2s;
    }

    .password-toggle:hover {
        color: var(--text-main);
    }

    /* Botones */
    .btn-save {
        background-color: var(--brand-green-bright);
        color: white;
        border: none;
        padding: 0.6rem 2rem;
        font-size: 14px;
        font-weight: 600;
        border-radius: 8px;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .btn-save:hover {
        background-color: #059669;
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(16, 185, 129, 0.2);
        color: white;
    }

    .btn-cancel {
        background-color: #fff;
        color: var(--text-muted);
        border: 1px solid var(--border-color);
        padding: 0.6rem 1.5rem;
        font-size: 14px;
        border-radius: 8px;
        transition: all 0.2s;
    }

    .btn-cancel:hover {
        background-color: #f9fafb;
        border-color: #d1d5db;
        color: var(--text-main);
    }
</style>

<div class="main-wrapper-fluid">
    <!-- Header -->
    <div class="header-minimal">
        <div>
            <div class="breadcrumb-text">@ViewData["Modulo"] / Usuarios</div>
            <h1>Registrar Nuevo Usuario</h1>
        </div>
        <a asp-page="Index" class="btn-cancel text-decoration-none d-flex align-items-center gap-2">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6" /></svg>
            Volver al listado
        </a>
    </div>

    <!-- Card Formulario -->
    <div class="card-clean">
        <div class="card-body p-4 p-lg-5">
            <form method="post" id="usuarioForm">
                
                <!-- SECCIÓN 1: CREDENCIALES -->
                <div class="form-section-label">Credenciales de Acceso</div>
                <div class="row g-4 mb-4">
                    <div class="col-xl-6 col-md-6">
                        <label asp-for="Usuario.Username" class="form-label">Nombre de Usuario <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text">@@</span>
                            <input asp-for="Usuario.Username" class="form-control" id="usernameInput" placeholder="ej: juan.perez" autocomplete="off" />
                        </div>
                        <span asp-validation-for="Usuario.Username" class="text-danger" style="font-size:11px"></span>
                        <div class="text-muted mt-1" style="font-size:11px;">
                            Solo letras, números, puntos y guiones bajos
                        </div>
                    </div>
                    <div class="col-xl-6 col-md-6">
                        <label asp-for="Usuario.Password" class="form-label">Contraseña <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                                </svg>
                            </span>
                            <input asp-for="Usuario.Password" type="password" class="form-control" id="passwordInput" placeholder="Mínimo 6 caracteres" autocomplete="new-password" />
                            <button type="button" class="password-toggle" id="togglePassword" tabindex="-1">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" id="eyeIcon">
                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
                                </svg>
                            </button>
                        </div>
                        <span asp-validation-for="Usuario.Password" class="text-danger" style="font-size:11px"></span>
                        <div class="password-strength" id="passwordStrength">
                            <div class="password-strength-bar" id="passwordStrengthBar" style="width: 0%;"></div>
                        </div>
                        <div class="strength-text" id="strengthText"></div>
                    </div>
                </div>

                <!-- SECCIÓN 2: ASIGNACIONES -->
                <div class="form-section-label">Asignaciones</div>
                <div class="row g-4 mb-4">
                    <div class="col-xl-6 col-md-6">
                        <label asp-for="Usuario.EmpleadoId" class="form-label">Empleado Asociado</label>
                        <select asp-for="Usuario.EmpleadoId" asp-items="Model.EmpleadosSelect" class="form-select" id="empleadoSelect">
                            <option value="">-- Sin empleado asociado --</option>
                        </select>
                        <span asp-validation-for="Usuario.EmpleadoId" class="text-danger" style="font-size:11px"></span>
                    </div>
                    <div class="col-xl-6 col-md-6">
                        <label asp-for="Usuario.RolId" class="form-label">Rol del Usuario <span class="text-danger">*</span></label>
                        <select asp-for="Usuario.RolId" asp-items="Model.RolesSelect" class="form-select" id="rolSelect">
                            <option value="">-- Seleccione un rol --</option>
                        </select>
                        <span asp-validation-for="Usuario.RolId" class="text-danger" style="font-size:11px"></span>
                        <div id="rolPreview" class="mt-2"></div>
                    </div>
                </div>

                <!-- SECCIÓN 3: RESUMEN -->
                <div class="form-section-label">Resumen del Usuario</div>
                <div class="resumen-card" id="resumenCard">
                    <div class="resumen-grid">
                        <div class="resumen-item">
                            <div class="label">Username</div>
                            <div class="valor username-preview" id="resumenUsername">—</div>
                        </div>
                        <div class="resumen-item">
                            <div class="label">Empleado</div>
                            <div class="valor" id="resumenEmpleado">No asignado</div>
                        </div>
                        <div class="resumen-item">
                            <div class="label">Rol</div>
                            <div class="valor" id="resumenRol">—</div>
                        </div>
                        <div class="resumen-item">
                            <div class="label">Seguridad</div>
                            <div class="valor" id="resumenSeguridad">—</div>
                        </div>
                    </div>
                </div>

                <!-- ACCIONES -->
                <div class="d-flex justify-content-between align-items-center pt-4 mt-4 border-top">
                    <span class="text-muted" style="font-size: 13px;">Los campos marcados con <span class="text-danger">*</span> son obligatorios</span>
                    <div class="d-flex gap-3">
                        <a asp-page="Index" class="btn-cancel text-decoration-none">Cancelar</a>
                        <button type="submit" class="btn-save">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><polyline points="17 11 19 13 23 9"/></svg>
                            Crear Usuario
                        </button>
                    </div>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        // ── Mostrar/Ocultar contraseña ──
        const togglePassword = document.getElementById('togglePassword');
        const passwordInput = document.getElementById('passwordInput');
        const eyeIcon = document.getElementById('eyeIcon');
        
        togglePassword.addEventListener('click', function() {
            const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
            passwordInput.setAttribute('type', type);
            
            if (type === 'text') {
                eyeIcon.innerHTML = '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/>';
            } else {
                eyeIcon.innerHTML = '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>';
            }
        });

        // ── Verificar fortaleza de contraseña ──
        passwordInput.addEventListener('input', function() {
            const password = this.value;
            const bar = document.getElementById('passwordStrengthBar');
            const text = document.getElementById('strengthText');
            const resumenSeguridad = document.getElementById('resumenSeguridad');
            
            let strength = 0;
            let color = '';
            let label = '';
            let className = '';
            
            if (password.length >= 6) strength++;
            if (password.length >= 10) strength++;
            if (/[A-Z]/.test(password)) strength++;
            if (/[0-9]/.test(password)) strength++;
            if (/[^A-Za-z0-9]/.test(password)) strength++;
            
            switch (true) {
                case (strength <= 1):
                    color = '#dc2626';
                    label = 'Débil';
                    className = 'strength-weak';
                    break;
                case (strength === 2):
                    color = '#f59e0b';
                    label = 'Regular';
                    className = 'strength-fair';
                    break;
                case (strength === 3):
                    color = '#10b981';
                    label = 'Buena';
                    className = 'strength-good';
                    break;
                case (strength >= 4):
                    color = '#059669';
                    label = 'Fuerte';
                    className = 'strength-strong';
                    break;
            }
            
            const width = password.length > 0 ? ((strength / 5) * 100) : 0;
            bar.style.width = width + '%';
            bar.style.backgroundColor = color;
            text.textContent = password.length > 0 ? 'Seguridad: ' + label : '';
            text.className = 'strength-text ' + (password.length > 0 ? className : '');
            
            resumenSeguridad.textContent = password.length > 0 ? label : '—';
            resumenSeguridad.style.color = password.length > 0 ? color : '';
        });

        // ── Actualizar resumen ──
        const usernameInput = document.getElementById('usernameInput');
        const empleadoSelect = document.getElementById('empleadoSelect');
        const rolSelect = document.getElementById('rolSelect');
        
        function actualizarResumen() {
            // Username
            const username = usernameInput.value || '—';
            document.getElementById('resumenUsername').textContent = username ? '@@' + username : '—';
            
            // Empleado
            const empleadoText = empleadoSelect.options[empleadoSelect.selectedIndex]?.text || 'No asignado';
            document.getElementById('resumenEmpleado').textContent = empleadoText;
            
            // Rol
            const rolText = rolSelect.options[rolSelect.selectedIndex]?.text || '—';
            document.getElementById('resumenRol').textContent = rolText;
            
            // Rol preview badge
            const rolPreview = document.getElementById('rolPreview');
            if (rolSelect.value) {
                const rolNombre = rolText.toLowerCase();
                let rolClass = 'rol-otro';
                if (rolNombre.includes('admin')) rolClass = 'rol-admin';
                else if (rolNombre.includes('supervisor')) rolClass = 'rol-supervisor';
                else if (rolNombre.includes('usuario')) rolClass = 'rol-usuario';
                
                rolPreview.innerHTML = `
                    <span class="badge-rol-preview ${rolClass}">
                        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                            <path d="M12 1L3 5v6c0 5.5 3.84 10.74 9 12 5.16-1.26 9-6.5 9-12V5l-9-4z"/>
                        </svg>
                        ${rolText}
                    </span>
                `;
            } else {
                rolPreview.innerHTML = '';
            }
        }
        
        usernameInput.addEventListener('input', actualizarResumen);
        empleadoSelect.addEventListener('change', actualizarResumen);
        rolSelect.addEventListener('change', actualizarResumen);
        
        // Inicializar
        actualizarResumen();
    </script>
}