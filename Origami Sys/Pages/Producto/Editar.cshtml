@page "{id:int}"
@model Origami_Sys.Pages.Producto.EditarModel
@{
    ViewData["Title"] = "Editar Producto";
    ViewData["Modulo"] = "Inventario";
}

<style>
    :root {
        --g-dark: #1a4332;
        --g-bright: #10b981;
        --border: #e5e7eb;
        --text: #1f2937;
        --muted: #6b7280;
    }
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 20px;
        padding-bottom: 16px;
        border-bottom: 1px solid var(--border);
    }
    .page-header h1 {
        font-size: 20px;
        font-weight: 700;
        color: var(--g-dark);
        margin: 0 0 3px 0;
    }
    .breadcrumb-txt {
        font-size: 11px;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: .8px;
    }
    .card-clean {
        background: white;
        border: 1px solid var(--border);
        border-radius: 12px;
        box-shadow: 0 1px 4px rgba(0,0,0,.05);
        overflow: hidden;
    }
    .section-label {
        font-size: 10.5px;
        font-weight: 700;
        color: var(--g-bright);
        text-transform: uppercase;
        letter-spacing: .6px;
        display: flex;
        align-items: center;
        gap: 10px;
        margin: 0 0 14px 0;
    }
    .section-label::after {
        content: "";
        flex: 1;
        height: 1px;
        background: #f1f5f9;
    }
    .form-label {
        font-size: 12px;
        font-weight: 600;
        color: #374151;
        margin-bottom: 5px;
    }
    .form-control, .form-select {
        font-size: 13px;
        border-color: var(--border);
        border-radius: 7px;
        padding: 7px 11px;
        transition: border-color .15s, box-shadow .15s;
    }
    .form-control:focus, .form-select:focus {
        border-color: var(--g-bright);
        box-shadow: 0 0 0 3px rgba(16,185,129,.1);
        outline: none;
    }
    .stock-box {
        background: #fafafa;
        border: 1px solid #f1f5f9;
        border-radius: 10px;
        padding: 16px;
        text-align: center;
    }
    .stock-box .form-control {
        font-size: 22px;
        font-weight: 700;
        text-align: center;
        border-color: transparent;
        background: transparent;
        padding: 4px;
    }
    .stock-box .form-control:focus {
        border-color: var(--g-bright);
        background: white;
        box-shadow: 0 0 0 3px rgba(16,185,129,.1);
    }
    .stock-hint {
        font-size: 11px;
        color: var(--muted);
        margin-top: 5px;
    }
    /* Indicador de cambios pendientes */
    .change-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: #f59e0b;
        display: none;
        margin-left: 6px;
    }
    .change-dot.visible { display: inline-block; }
    /* Botones */
    .btn-save {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        background: var(--g-dark);
        color: white;
        border: none;
        padding: 8px 22px;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        transition: background .15s, transform .1s, box-shadow .15s;
    }
    .btn-save:hover {
        background: #2d5a3d;
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(26,67,50,.2);
    }
    .btn-back {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: white;
        color: var(--muted);
        border: 1px solid var(--border);
        padding: 8px 16px;
        border-radius: 8px;
        font-size: 13px;
        text-decoration: none;
        transition: background .15s, color .15s;
    }
    .btn-back:hover { background: #f9fafb; color: var(--text); }
    .input-group-text {
        background: #f9fafb;
        border-color: var(--border);
        font-size: 13px;
        color: var(--muted);
    }
    /* Badge de estado live */
    .badge-live {
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 5px;
    }
    .badge-ok-live { background: #dcfce7; color: #166534; }
    .badge-warn-live { background: #fee2e2; color: #991b1b; }
</style>

<div class="page-header">
    <div>
        <div class="breadcrumb-txt">@ViewData["Modulo"] / Editar</div>
        <div class="d-flex align-items-center gap-2 mt-1">
            <h1>@Model.Producto.Nombre</h1>
            <span class="change-dot" id="changeDot" title="Cambios sin guardar"></span>
        </div>
        <span id="badgeLive" class="badge-live mt-1"></span>
    </div>
    <a asp-page="Index" class="btn-back">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m15 18-6-6 6-6"/></svg>
        Volver
    </a>
</div>

<div class="card-clean">
    <div class="card-body p-4">
        <form method="post" id="formEditar">
            <input type="hidden" asp-for="Producto.Id" />

            <div class="section-label">Identificación</div>
            <div class="row g-3 mb-4">
                <div class="col-md-3">
                    <label asp-for="Producto.CodigoBarra" class="form-label">Código de Barra</label>
                    <input asp-for="Producto.CodigoBarra" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Producto.Nombre" class="form-label">Nombre <span class="text-danger">*</span></label>
                    <input asp-for="Producto.Nombre" class="form-control" />
                    <span asp-validation-for="Producto.Nombre" class="text-danger" style="font-size:11px"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="Producto.Tipo" class="form-label">Tipo / Variante</label>
                    <input asp-for="Producto.Tipo" class="form-control" />
                </div>
            </div>

            <div class="section-label">Comercialización</div>
            <div class="row g-3 mb-4">
                <div class="col-md-7">
                    <label asp-for="Producto.CategoriaId" class="form-label">Categoría <span class="text-danger">*</span></label>
                    <select asp-for="Producto.CategoriaId" asp-items="Model.CategoriasSelect" class="form-select">
                        <option value="">-- Seleccione --</option>
                    </select>
                    <span asp-validation-for="Producto.CategoriaId" class="text-danger" style="font-size:11px"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="Producto.PrecioVenta" class="form-label">Precio de Venta <span class="text-danger">*</span></label>
                    <div class="input-group">
                        <span class="input-group-text">$</span>
                        <input asp-for="Producto.PrecioVenta" class="form-control fw-bold" />
                    </div>
                    <span asp-validation-for="Producto.PrecioVenta" class="text-danger" style="font-size:11px"></span>
                </div>
            </div>

            <div class="section-label">Stock</div>
            <div class="row g-3 mb-4">
                <div class="col-md-3">
                    <div class="stock-box">
                        <label asp-for="Producto.StockActual" class="form-label d-block">Stock Actual</label>
                        <input asp-for="Producto.StockActual" class="form-control" id="stockActual" />
                        <div class="stock-hint">unidades en almacén</div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stock-box">
                        <label asp-for="Producto.StockMinimo" class="form-label d-block">Stock Mínimo</label>
                        <input asp-for="Producto.StockMinimo" class="form-control" id="stockMinimo" />
                        <div class="stock-hint">alerta de reabastecimiento</div>
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-between align-items-center pt-3" style="border-top:1px solid #f3f4f6">
                <small class="text-muted">Los campos con <span class="text-danger">*</span> son obligatorios</small>
                <div class="d-flex gap-2">
                    <a asp-page="Index" class="btn-back">Cancelar</a>
                    <button type="submit" class="btn-save">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                        Guardar Cambios
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        // ── Badge de estado live ──
        const stockActualInput  = document.getElementById('stockActual');
        const stockMinimoInput  = document.getElementById('stockMinimo');
        const badgeLive         = document.getElementById('badgeLive');
        const changeDot         = document.getElementById('changeDot');
        const form              = document.getElementById('formEditar');
        const originalValues    = new FormData(form);

        function actualizarBadge() {
            const actual  = parseInt(stockActualInput.value) || 0;
            const minimo  = parseInt(stockMinimoInput.value) || 0;
            if (actual <= minimo) {
                badgeLive.className = 'badge-live badge-warn-live mt-1';
                badgeLive.innerHTML = `<svg width="11" height="11" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path></svg> Stock crítico`;
            } else {
                badgeLive.className = 'badge-live badge-ok-live mt-1';
                badgeLive.innerHTML = `<svg width="11" height="11" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg> Stock OK`;
            }
        }

        // Punto naranja de cambios sin guardar
        form.querySelectorAll('input, select').forEach(el => {
            el.addEventListener('input', () => changeDot.classList.add('visible'));
        });

        // Advertir si cierra con cambios sin guardar
        let guardado = false;
        form.addEventListener('submit', () => guardado = true);
        window.addEventListener('beforeunload', e => {
            if (!guardado && changeDot.classList.contains('visible')) {
                e.preventDefault();
                e.returnValue = '';
            }
        });

        stockActualInput.addEventListener('input', actualizarBadge);
        stockMinimoInput.addEventListener('input', actualizarBadge);
        actualizarBadge(); // inicializar
    </script>
}