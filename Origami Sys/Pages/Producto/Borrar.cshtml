@page "{id:int}"
@model Origami_Sys.Pages.Producto.BorrarModel
@{
    ViewData["Title"] = "Eliminar Producto";
    ViewData["Modulo"] = "Inventario";
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>
    :root {
        --brand-green: #1a4332;
        --brand-danger: #be123c; /* Rojo elegante */
        --brand-danger-light: #fff1f2;
        --border-color: #e5e7eb;
        --text-main: #1f2937;
        --text-muted: #6b7280;
        --bg-body: #f3f4f6;
    }

    body {
        background-color: var(--bg-body);
        font-family: 'Inter', sans-serif;
    }

    .main-wrapper-fluid {
        width: 100%;
        padding: 1.5rem 2rem;
    }

    /* Header */
    .header-minimal {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
    }

        .header-minimal h1 {
            font-size: 1.5rem;
            font-weight: 700;
            margin: 0;
            color: var(--brand-green);
        }

    /* Card de eliminación */
    .card-destructive {
        background: #ffffff;
        border: 1px solid var(--border-color);
        border-radius: 12px;
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.05);
        overflow: hidden;
    }

    /* Banner de Advertencia */
    .warning-banner {
        background-color: var(--brand-danger-light);
        border-left: 4px solid var(--brand-danger);
        padding: 1.5rem 2rem;
        display: flex;
        gap: 1rem;
        align-items: center;
    }

    .warning-icon {
        color: var(--brand-danger);
        background: white;
        border-radius: 50%;
        padding: 8px;
        display: flex;
        box-shadow: 0 2px 4px rgba(190, 18, 60, 0.1);
    }

    /* Caja de Resumen del Producto */
    .product-summary {
        background-color: #fafafa;
        border: 1px solid #f1f5f9;
        border-radius: 10px;
        padding: 1.5rem;
        margin: 2rem 0;
    }

    .detail-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1.5rem;
    }

    .info-label {
        font-size: 11px;
        font-weight: 700;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 4px;
    }

    .info-value {
        font-size: 15px;
        font-weight: 600;
        color: var(--text-main);
    }

    /* Botones */
    .btn-action {
        padding: 0.6rem 1.5rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: 14px;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
    }

    .btn-delete {
        background-color: var(--brand-danger);
        color: white;
        border: none;
    }

        .btn-delete:hover {
            background-color: #9f1239;
            box-shadow: 0 4px 12px rgba(190, 18, 60, 0.2);
            color: white;
        }

    .btn-cancel {
        background-color: white;
        color: var(--text-muted);
        border: 1px solid var(--border-color);
    }

        .btn-cancel:hover {
            background-color: #f9fafb;
            color: var(--text-main);
        }

    .stock-warning {
        background: #fffbeb;
        color: #92400e;
        border: 1px solid #fde68a;
        padding: 0.75rem 1rem;
        border-radius: 8px;
        font-size: 13px;
        margin-top: 1rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }
</style>

<div class="main-wrapper-fluid">
    <!-- Header -->
    <div class="header-minimal">
        <div>
            <div class="breadcrumb-text text-muted mb-1" style="font-size: 11px; text-transform: uppercase; letter-spacing: 1px;">
                @ViewData["Modulo"] / Eliminación de Registro
            </div>
            <h1>Eliminar Producto</h1>
        </div>
        <a asp-page="Index" class="btn-action btn-cancel">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6" /></svg>
            Cancelar y volver
        </a>
    </div>

    <!-- Contenido -->
    <div class="card-destructive">
        <!-- Advertencia Crítica -->
        <div class="warning-banner">
            <div class="warning-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" /><line x1="12" y1="9" x2="12" y2="13" /><line x1="12" y1="17" x2="12.01" y2="17" /></svg>
            </div>
            <div>
                <div style="font-size: 16px; font-weight: 700; color: #991b1b;">Acción Irreversible</div>
                <div style="font-size: 14px; color: #b91c1c; opacity: 0.8;">Estás a punto de eliminar este producto del inventario de forma permanente.</div>
            </div>
        </div>

        <div class="card-body p-4 p-lg-5">
            <div class="info-label">Producto Seleccionado</div>
            <div class="product-summary">
                <div class="row align-items-center">
                    <div class="col-lg-6">
                        <div style="font-size: 22px; font-weight: 700; color: var(--brand-green);">@Model.Producto.Nombre</div>
                        <div class="font-monospace text-muted mt-1">Ref: @Model.Producto.CodigoBarra</div>
                    </div>
                    <div class="col-lg-6">
                        <div class="detail-grid mt-3 mt-lg-0">
                            <div>
                                <div class="info-label">Existencia</div>
                                <div class="info-value">@Model.Producto.StockActual unidades</div>
                            </div>
                            <div>
                                <div class="info-label">Categoría</div>
                                <div class="info-value">@(Model.Producto.Categoria?.Nombre ?? "—")</div>
                            </div>
                            <div>
                                <div class="info-label">Valor Venta</div>
                                <div class="info-value text-success">@Model.Producto.PrecioVenta.ToString("C")</div>
                            </div>
                        </div>
                    </div>
                </div>

                @if (Model.Producto.StockActual > 0)
                {
                    <div class="stock-warning">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" /></svg>
                        <strong>Aviso:</strong> Este producto aún tiene <b>@Model.Producto.StockActual</b> unidades en inventario físico.
                    </div>
                }
            </div>

            <!-- Acciones Finales -->
            <div class="d-flex justify-content-between align-items-center pt-4 border-top">
                <p class="text-muted m-0" style="font-size: 13px;">
                    ¿Confirmas que deseas proceder con la baja definitiva?
                </p>
                <div class="d-flex gap-3">
                    <a asp-page="Index" class="btn-action btn-cancel">No, mantener producto</a>
                    <form method="post">
                        <input type="hidden" asp-for="Producto.Id" />
                        <button type="submit" class="btn-action btn-delete">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18" /><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6" /><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2" /><line x1="10" y1="11" x2="10" y2="17" /><line x1="14" y1="11" x2="14" y2="17" /></svg>
                            Confirmar Eliminación
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>