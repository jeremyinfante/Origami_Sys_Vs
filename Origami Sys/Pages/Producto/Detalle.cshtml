@page "{id:int}"
@model Origami_Sys.Pages.Producto.DetalleModel
@{
    ViewData["Title"] = "Detalle del Producto";
    ViewData["Modulo"] = "Inventario";
    var stockCritico = Model.Producto.StockActual <= Model.Producto.StockMinimo;
    var pct = Model.Producto.StockMinimo > 0
        ? Math.Min(100, (int)((double)Model.Producto.StockActual / Model.Producto.StockMinimo * 100))
        : 100;
    var barColor = pct <= 100 && stockCritico ? "#ef4444" : pct < 150 ? "#f59e0b" : "#10b981";
}

<style>
    :root {
        --g-dark: #1a4332;
        --g-bright: #10b981;
        --border: #e5e7eb;
        --text: #1f2937;
        --muted: #6b7280;
    }
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 20px;
        padding-bottom: 16px;
        border-bottom: 1px solid var(--border);
    }
    .page-header h1 {
        font-size: 22px;
        font-weight: 700;
        color: var(--g-dark);
        margin: 0 0 4px 0;
        letter-spacing: -.02em;
    }
    .breadcrumb-txt {
        font-size: 11px;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: .8px;
    }
    .badge-status {
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 5px;
    }
    .status-ok   { background: #dcfce7; color: #166534; }
    .status-warn { background: #fee2e2; color: #991b1b; }
    /* KPIs */
    .kpi-row {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
        margin-bottom: 16px;
    }
    .kpi-card {
        background: white;
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 16px 20px;
        box-shadow: 0 1px 3px rgba(0,0,0,.04);
    }
    .kpi-label {
        font-size: 10.5px;
        font-weight: 700;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: .5px;
        margin-bottom: 6px;
    }
    .kpi-value {
        font-size: 26px;
        font-weight: 700;
        color: var(--g-dark);
        line-height: 1;
    }
    .kpi-value.green { color: var(--g-bright); }
    .kpi-sub {
        font-size: 11px;
        color: var(--muted);
        margin-top: 4px;
    }
    /* Barra de stock */
    .stock-bar-wrap {
        background: #f3f4f6;
        border-radius: 99px;
        height: 6px;
        margin-top: 8px;
        overflow: hidden;
    }
    .stock-bar-fill {
        height: 100%;
        border-radius: 99px;
        transition: width .5s ease;
    }
    /* Card de detalles */
    .detail-card {
        background: white;
        border: 1px solid var(--border);
        border-radius: 10px;
        box-shadow: 0 1px 3px rgba(0,0,0,.04);
        overflow: hidden;
    }
    .detail-card-header {
        padding: 12px 18px;
        background: #fafafa;
        border-bottom: 1px solid var(--border);
        font-size: 11px;
        font-weight: 700;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: .5px;
    }
    .detail-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 0;
    }
    .detail-item {
        padding: 14px 18px;
        border-bottom: 1px solid #f3f4f6;
        border-right: 1px solid #f3f4f6;
    }
    .detail-item:nth-child(even) { border-right: none; }
    .detail-item:nth-last-child(-n+2) { border-bottom: none; }
    .d-lbl {
        font-size: 10.5px;
        font-weight: 700;
        color: var(--g-bright);
        text-transform: uppercase;
        letter-spacing: .4px;
        margin-bottom: 3px;
    }
    .d-val {
        font-size: 14px;
        font-weight: 500;
        color: var(--text);
    }
    /* Botones */
    .btn-primary-action {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        background: var(--g-dark);
        color: white;
        border: none;
        padding: 8px 18px;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 600;
        text-decoration: none;
        transition: background .15s, transform .1s;
    }
    .btn-primary-action:hover {
        background: #2d5a3d;
        color: white;
        transform: translateY(-1px);
    }
    .btn-secondary-action {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: white;
        color: var(--muted);
        border: 1px solid var(--border);
        padding: 8px 16px;
        border-radius: 8px;
        font-size: 13px;
        text-decoration: none;
        transition: background .15s, color .15s;
    }
    .btn-secondary-action:hover { background: #f9fafb; color: var(--text); }
    .btn-danger-action {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: #fff0f0;
        color: #be123c;
        border: 1px solid #fecdd3;
        padding: 8px 16px;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 600;
        text-decoration: none;
        cursor: pointer;
        transition: background .15s;
    }
    .btn-danger-action:hover { background: #ffe4e6; color: #9f1239; }
</style>

<!-- Header -->
<div class="page-header">
    <div>
        <div class="breadcrumb-txt">@ViewData["Modulo"] / Detalle</div>
        <div class="d-flex align-items-center gap-2 mt-1">
            <h1>@Model.Producto.Nombre</h1>
            @if (stockCritico)
            {
                <span class="badge-status status-warn">⚠ Stock Crítico</span>
            }
            else
            {
                <span class="badge-status status-ok">✓ Disponible</span>
            }
        </div>
        @if (!string.IsNullOrEmpty(Model.Producto.CodigoBarra))
        {
            <div style="font-size:12px;color:var(--muted);font-family:monospace;margin-top:3px">
                Ref: @Model.Producto.CodigoBarra
            </div>
        }
    </div>
    <a asp-page="Index" class="btn-secondary-action">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m15 18-6-6 6-6"/></svg>
        Volver
    </a>
</div>

<!-- KPIs -->
<div class="kpi-row">
    <div class="kpi-card">
        <div class="kpi-label">Precio de Venta</div>
        <div class="kpi-value green">@Model.Producto.PrecioVenta.ToString("C")</div>
        <div class="kpi-sub">precio unitario</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-label">Stock Actual</div>
        <div class="kpi-value" style="color:@barColor">@Model.Producto.StockActual</div>
        <div class="stock-bar-wrap">
            <div class="stock-bar-fill" style="width:@(Math.Min(pct,100))%;background:@barColor"></div>
        </div>
        <div class="kpi-sub">mínimo: @Model.Producto.StockMinimo unidades</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-label">Categoría</div>
        <div class="kpi-value" style="font-size:18px">@(Model.Producto.Categoria?.Nombre ?? "—")</div>
        <div class="kpi-sub">@(Model.Producto.Tipo ?? "Sin tipo definido")</div>
    </div>
</div>

<!-- Detalles -->
<div class="detail-card mb-4">
    <div class="detail-card-header">Información completa</div>
    <div class="detail-grid">
        <div class="detail-item">
            <div class="d-lbl">Código de Barras</div>
            <div class="d-val" style="font-family:monospace">@(Model.Producto.CodigoBarra ?? "—")</div>
        </div>
        <div class="detail-item">
            <div class="d-lbl">Tipo / Variante</div>
            <div class="d-val">@(Model.Producto.Tipo ?? "—")</div>
        </div>
        <div class="detail-item">
            <div class="d-lbl">Categoría</div>
            <div class="d-val">@(Model.Producto.Categoria?.Nombre ?? "Sin categoría")</div>
        </div>
        <div class="detail-item">
            <div class="d-lbl">Precio de Venta</div>
            <div class="d-val" style="color:var(--g-bright);font-weight:700">@Model.Producto.PrecioVenta.ToString("C")</div>
        </div>
        <div class="detail-item">
            <div class="d-lbl">Stock Actual</div>
            <div class="d-val">@Model.Producto.StockActual unidades</div>
        </div>
        <div class="detail-item">
            <div class="d-lbl">Stock Mínimo</div>
            <div class="d-val">@Model.Producto.StockMinimo unidades</div>
        </div>
    </div>
</div>

<!-- Acciones -->
<div class="d-flex gap-2">
    <a class="btn-primary-action" asp-page="Editar" asp-route-id="@Model.Producto.Id">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
        Editar Producto
    </a>
    <button class="btn-danger-action" onclick="abrirModalEliminar()">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
        Eliminar
    </button>
</div>

<!-- Modal de confirmación -->
<div id="modalOverlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:1000;align-items:center;justify-content:center;">
    <div style="background:white;border-radius:14px;width:100%;max-width:420px;overflow:hidden;box-shadow:0 20px 60px rgba(0,0,0,.2);animation:slideUp .2s ease">
        <!-- Franja roja -->
        <div style="background:#be123c;padding:18px 22px;display:flex;align-items:center;gap:12px">
            <div style="background:rgba(255,255,255,.15);border-radius:50%;padding:8px;display:flex">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
                    <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                    <line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
                </svg>
            </div>
            <div>
                <div style="color:white;font-weight:700;font-size:15px">Eliminar producto</div>
                <div style="color:rgba(255,255,255,.75);font-size:12px">Esta acción no se puede deshacer</div>
            </div>
        </div>
        <!-- Cuerpo -->
        <div style="padding:22px">
            <p style="font-size:14px;color:#374151;margin:0 0 14px 0">
                ¿Confirmas que deseas eliminar <strong>@Model.Producto.Nombre</strong> del inventario?
            </p>
            @if (Model.Producto.StockActual > 0)
            {
                <div style="background:#fffbeb;border:1px solid #fde68a;border-radius:8px;padding:10px 14px;font-size:12px;color:#92400e;display:flex;gap:8px;align-items:center;margin-bottom:14px">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                    Aún tiene <strong>@Model.Producto.StockActual</strong> unidades en inventario.
                </div>
            }
            <div style="display:flex;gap:10px;justify-content:flex-end">
                <button onclick="cerrarModal()" style="background:white;border:1px solid #e5e7eb;color:#6b7280;padding:8px 18px;border-radius:7px;font-size:13px;cursor:pointer;transition:background .15s" onmouseover="this.style.background='#f9fafb'" onmouseout="this.style.background='white'">
                    Cancelar
                </button>
                <form method="post" asp-page="Borrar" asp-route-id="@Model.Producto.Id" style="margin:0">
                    <button type="submit" style="background:#be123c;color:white;border:none;padding:8px 18px;border-radius:7px;font-size:13px;font-weight:600;cursor:pointer;display:inline-flex;align-items:center;gap:6px;transition:background .15s" onmouseover="this.style.background='#9f1239'" onmouseout="this.style.background='#be123c'">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>
                        Sí, eliminar
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<style>
    @@keyframes slideUp {
        from { transform: translateY(20px); opacity: 0; }
        to   { transform: translateY(0);    opacity: 1; }
    }
</style>
<script>
    const overlay = document.getElementById('modalOverlay');
    function abrirModalEliminar() {
        overlay.style.display = 'flex';
        document.body.style.overflow = 'hidden';
    }
    function cerrarModal() {
        overlay.style.display = 'none';
        document.body.style.overflow = '';
    }
    overlay.addEventListener('click', e => { if (e.target === overlay) cerrarModal(); });
    document.addEventListener('keydown', e => { if (e.key === 'Escape') cerrarModal(); });
</script>
}