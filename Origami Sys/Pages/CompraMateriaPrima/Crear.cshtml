@page
@model Origami_Sys.Pages.CompraMateriaPrima.CrearModel
@{
    ViewData["Title"] = "Registrar Compra";
    ViewData["Modulo"] = "Inventario";
}

<style>
    :root{--g-dark:#1a4332;--g-bright:#10b981;--border:#e5e7eb;--text:#1f2937;--muted:#6b7280;}
    .page-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;padding-bottom:16px;border-bottom:1px solid var(--border);}
    .page-header h1{font-size:20px;font-weight:700;color:var(--g-dark);margin:0;}
    .breadcrumb-txt{font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.8px;margin-bottom:3px;}
    .card-clean{background:white;border:1px solid var(--border);border-radius:12px;box-shadow:0 1px 4px rgba(0,0,0,.05);}
    .section-label{font-size:10.5px;font-weight:700;color:var(--g-bright);text-transform:uppercase;letter-spacing:.6px;display:flex;align-items:center;gap:10px;margin:0 0 14px 0;}
    .section-label::after{content:"";flex:1;height:1px;background:#f1f5f9;}
    .form-label{font-size:12px;font-weight:600;color:#374151;margin-bottom:5px;}
    .form-control,.form-select{font-size:13px;border-color:var(--border);border-radius:7px;padding:7px 11px;transition:border-color .15s,box-shadow .15s;}
    .form-control:focus,.form-select:focus{border-color:var(--g-bright);box-shadow:0 0 0 3px rgba(16,185,129,.1);outline:none;}
    .cost-box{background:#f0fdf4;border:1px solid #bbf7d0;border-radius:10px;padding:16px;}
    .cost-box .form-control{font-size:18px;font-weight:700;color:#166534;border-color:transparent;background:transparent;padding:2px;}
    .cost-box .form-control:focus{border-color:var(--g-bright);background:white;}
    .btn-save{display:inline-flex;align-items:center;gap:7px;background:var(--g-dark);color:white;border:none;padding:8px 22px;border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;transition:all .15s;}
    .btn-save:hover{background:#2d5a3d;transform:translateY(-1px);}
    .btn-back{display:inline-flex;align-items:center;gap:6px;background:white;color:var(--muted);border:1px solid var(--border);padding:8px 16px;border-radius:8px;font-size:13px;text-decoration:none;transition:all .15s;}
    .btn-back:hover{background:#f9fafb;color:var(--text);}
    .input-icon-wrap{position:relative;}
    .input-icon-wrap svg{position:absolute;left:10px;top:50%;transform:translateY(-50%);color:var(--muted);pointer-events:none;}
    .input-icon-wrap .form-control{padding-left:34px;}
</style>

<div class="page-header">
    <div>
        <div class="breadcrumb-txt">@ViewData["Modulo"] / Compras / Nueva</div>
        <h1>Registrar Compra</h1>
    </div>
    <a asp-page="Index" class="btn-back">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m15 18-6-6 6-6"/></svg>
        Volver
    </a>
</div>

<div class="card-clean">
    <div class="card-body p-4">
        <form method="post">
            <div class="section-label">Detalles de adquisición</div>
            <div class="row g-3 mb-4">
                <div class="col-md-5">
                    <label asp-for="Compra.MateriaPrimaId" class="form-label">Materia Prima <span class="text-danger">*</span></label>
                    <select asp-for="Compra.MateriaPrimaId" asp-items="Model.MateriasSelect" class="form-select">
                        <option value="">-- Seleccione el insumo --</option>
                    </select>
                    <span asp-validation-for="Compra.MateriaPrimaId" class="text-danger" style="font-size:11px"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="Compra.Fecha" class="form-label">Fecha de Compra</label>
                    <input asp-for="Compra.Fecha" type="date" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label asp-for="Compra.Proveedor" class="form-label">Proveedor</label>
                    <div class="input-icon-wrap">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                        <input asp-for="Compra.Proveedor" class="form-control" placeholder="Nombre de la empresa o contacto" />
                    </div>
                </div>
            </div>

            <div class="section-label">Cantidades y Costos</div>
            <div class="row g-3 mb-4">
                <div class="col-md-3">
                    <label asp-for="Compra.Cantidad" class="form-label">Cantidad Comprada <span class="text-danger">*</span></label>
                    <input asp-for="Compra.Cantidad" class="form-control" placeholder="0.00" />
                    <span asp-validation-for="Compra.Cantidad" class="text-danger" style="font-size:11px"></span>
                </div>
                <div class="col-md-4">
                    <div class="cost-box">
                        <label asp-for="Compra.CostoTotal" class="form-label d-block" style="color:#166534">Costo Total (RD$)</label>
                        <div class="d-flex align-items-center">
                            <span style="font-weight:700; color:#166534; margin-right:5px">$</span>
                            <input asp-for="Compra.CostoTotal" class="form-control" placeholder="0.00" />
                        </div>
                        <span asp-validation-for="Compra.CostoTotal" class="text-danger" style="font-size:11px"></span>
                    </div>
                </div>
                <div class="col-md-5">
                    <label asp-for="Compra.Observaciones" class="form-label">Observaciones internas</label>
                    <textarea asp-for="Compra.Observaciones" class="form-control" rows="2" placeholder="Nota adicional sobre la calidad o entrega..."></textarea>
                </div>
            </div>

            <div class="d-flex justify-content-between align-items-center pt-3" style="border-top:1px solid #f3f4f6">
                <div style="font-size:12px; color:var(--muted); display:flex; align-items:center; gap:6px;">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
                    Esta acción generará un <strong>Egreso</strong> en contabilidad automáticamente.
                </div>
                <div class="d-flex gap-2">
                    <a asp-page="Index" class="btn-back">Cancelar</a>
                    <button type="submit" class="btn-save">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                        Confirmar Registro
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}