@page
@model Origami_Sys.Pages.CompraMateriaPrima.IndexModel
@{
    ViewData["Title"] = "Compras de Materia Prima";
    ViewData["Modulo"] = "Inventario";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0">Compras de Materia Prima</h5>
    <a class="btn btn-sm btn-success" asp-page="Crear">+ Registrar Compra</a>
</div>

<table class="table table-sm table-striped">
    <thead>
        <tr>
            <th>Fecha</th>
            <th>Materia Prima</th>
            <th>Cantidad</th>
            <th>Costo Total</th>
            <th>Proveedor</th>
            <th>Observaciones</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var c in Model.Compras)
        {
            <tr>
                <td>@c.Fecha.ToString("dd/MM/yyyy")</td>
                <td>@c.MateriaPrima?.Nombre</td>
                <td>@c.Cantidad @c.MateriaPrima?.UnidadMedida</td>
                <td class="text-danger">@c.CostoTotal.ToString("C")</td>
                <td>@(c.Proveedor ?? "—")</td>
                <td>@(c.Observaciones ?? "—")</td>
                <td>
                    <a class="btn btn-danger btn-sm" asp-page="Borrar" asp-route-id="@c.Id">Anular</a>
                </td>
            </tr>
        }
    </tbody>
</table>